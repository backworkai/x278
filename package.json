{
  "name": "@backwork/x278",
  "version": "0.2.0",
  "description": "Agent-native prior authorization protocol reference implementation and TypeScript SDK.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/backworkai/x278.git"
  },
  "bugs": {
    "url": "https://github.com/backworkai/x278/issues"
  },
  "homepage": "https://github.com/backworkai/x278#readme",
  "keywords": [
    "x278",
    "prior-authorization",
    "healthcare",
    "fhir",
    "da-vinci-pas",
    "effect-ts",
    "typescript",
    "agents",
    "backwork"
  ],
  "type": "module",
  "packageManager": "bun@1.3.11",
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "engines": {
    "node": ">=20"
  },
  "typesVersions": {
    "*": {
      "sdk": [
        "dist/sdk.d.ts"
      ],
      "conformance": [
        "dist/conformance.d.ts"
      ],
      "types": [
        "dist/domain.d.ts"
      ],
      "schemas": [
        "dist/domain.d.ts"
      ],
      "evidence": [
        "dist/evidence.d.ts"
      ],
      "fhir-pas": [
        "dist/fhir-pas.d.ts"
      ],
      "http": [
        "dist/http.d.ts"
      ],
      "payer-agent": [
        "dist/payer-agent.d.ts"
      ],
      "policy": [
        "dist/policy.d.ts"
      ],
      "provider-client": [
        "dist/provider-client.d.ts"
      ],
      "signing": [
        "dist/signing.d.ts"
      ],
      "smart": [
        "dist/smart.d.ts"
      ],
      "subscriptions": [
        "dist/subscriptions.d.ts"
      ]
    }
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./sdk": {
      "import": {
        "types": "./dist/sdk.d.mts",
        "default": "./dist/sdk.mjs"
      },
      "require": {
        "types": "./dist/sdk.d.cts",
        "default": "./dist/sdk.cjs"
      }
    },
    "./conformance": {
      "import": {
        "types": "./dist/conformance.d.mts",
        "default": "./dist/conformance.mjs"
      },
      "require": {
        "types": "./dist/conformance.d.cts",
        "default": "./dist/conformance.cjs"
      }
    },
    "./types": {
      "import": {
        "types": "./dist/domain.d.mts",
        "default": "./dist/domain.mjs"
      },
      "require": {
        "types": "./dist/domain.d.cts",
        "default": "./dist/domain.cjs"
      }
    },
    "./schemas": {
      "import": {
        "types": "./dist/domain.d.mts",
        "default": "./dist/domain.mjs"
      },
      "require": {
        "types": "./dist/domain.d.cts",
        "default": "./dist/domain.cjs"
      }
    },
    "./fhir-pas": {
      "import": {
        "types": "./dist/fhir-pas.d.mts",
        "default": "./dist/fhir-pas.mjs"
      },
      "require": {
        "types": "./dist/fhir-pas.d.cts",
        "default": "./dist/fhir-pas.cjs"
      }
    },
    "./evidence": {
      "import": {
        "types": "./dist/evidence.d.mts",
        "default": "./dist/evidence.mjs"
      },
      "require": {
        "types": "./dist/evidence.d.cts",
        "default": "./dist/evidence.cjs"
      }
    },
    "./http": {
      "import": {
        "types": "./dist/http.d.mts",
        "default": "./dist/http.mjs"
      },
      "require": {
        "types": "./dist/http.d.cts",
        "default": "./dist/http.cjs"
      }
    },
    "./payer-agent": {
      "import": {
        "types": "./dist/payer-agent.d.mts",
        "default": "./dist/payer-agent.mjs"
      },
      "require": {
        "types": "./dist/payer-agent.d.cts",
        "default": "./dist/payer-agent.cjs"
      }
    },
    "./policy": {
      "import": {
        "types": "./dist/policy.d.mts",
        "default": "./dist/policy.mjs"
      },
      "require": {
        "types": "./dist/policy.d.cts",
        "default": "./dist/policy.cjs"
      }
    },
    "./provider-client": {
      "import": {
        "types": "./dist/provider-client.d.mts",
        "default": "./dist/provider-client.mjs"
      },
      "require": {
        "types": "./dist/provider-client.d.cts",
        "default": "./dist/provider-client.cjs"
      }
    },
    "./signing": {
      "import": {
        "types": "./dist/signing.d.mts",
        "default": "./dist/signing.mjs"
      },
      "require": {
        "types": "./dist/signing.d.cts",
        "default": "./dist/signing.cjs"
      }
    },
    "./smart": {
      "import": {
        "types": "./dist/smart.d.mts",
        "default": "./dist/smart.mjs"
      },
      "require": {
        "types": "./dist/smart.d.cts",
        "default": "./dist/smart.cjs"
      }
    },
    "./subscriptions": {
      "import": {
        "types": "./dist/subscriptions.d.mts",
        "default": "./dist/subscriptions.mjs"
      },
      "require": {
        "types": "./dist/subscriptions.d.cts",
        "default": "./dist/subscriptions.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "specs",
    "examples",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup && tsc -p tsconfig.build.json && bun run scripts/declaration-conditions.ts",
    "cert:check": "bun run scripts/certification-readiness.ts",
    "demo": "bun run src/demo.ts",
    "docker:down": "docker compose down --volumes --remove-orphans",
    "docker:fhir": "sh -c 'docker compose --profile fhir up --build --abort-on-container-exit --exit-code-from provider-fhir-scenario provider-fhir-scenario; status=$?; docker compose --profile fhir down --volumes --remove-orphans; exit $status'",
    "docker:realistic": "sh -c 'docker compose up --build --abort-on-container-exit --exit-code-from provider-scenario; status=$?; docker compose down --volumes --remove-orphans; exit $status'",
    "dogfood": "bun run src/dogfood.ts",
    "example:conformance": "bun run build && bun run examples/conformance-runner.ts",
    "example:http": "bun run build && bun run examples/http-client.ts",
    "example:mock": "bun run build && bun run examples/mock-provider-loop.ts",
    "payer:http": "bun run e2e/realistic/payer-api.ts",
    "prepare": "bun run build",
    "prove": "bun run dogfood && vitest run test/proof.test.ts",
    "prove:full": "bun run cert:check && bun run security:audit && bun run typecheck && bun run test && bun run test:live && bun run build && bun run release:smoke && bun run release:attw && bun run docker:realistic && bun run docker:fhir",
    "release:attw": "bun run scripts/attw.ts",
    "release:smoke": "bun run scripts/release-smoke.ts",
    "scenario:fhir": "bun run e2e/realistic/provider-fhir-scenario.ts",
    "scenario:realistic": "bun run e2e/realistic/provider-scenario.ts",
    "security:audit": "bun audit --audit-level=moderate",
    "test": "vitest run",
    "test:live": "RUN_LIVE_AGENT_TESTS=1 vitest run test/live-agents.test.ts",
    "test:all": "bun run typecheck && bun run test && bun run test:live",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "effect": "^3.21.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.100.0",
    "@arethetypeswrong/core": "^0.18.2",
    "@effect/vitest": "^0.29.0",
    "@openai/agents": "^0.11.5",
    "@types/bun": "^1.3.14",
    "tsup": "^8.5.1",
    "typescript": "5.9.3",
    "vitest": "3.2.4"
  }
}
